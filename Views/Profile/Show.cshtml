@model UserProfile
@{
    ViewData["Title"] = "Profile";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isOwner = User.Identity.IsAuthenticated && Model.UserId == currentUserId;
    var userFollowing = ViewBag.Following as List<string> ?? new List<string>();

    var currentFeed = ViewBag.feed as string ?? "feed";
    var postsToDisplay = currentFeed == "highlighted"
        ? (ViewBag.highlighted as List<PostViewModel> ?? new List<PostViewModel>())
        : (ViewBag.userPosts as List<PostViewModel> ?? new List<PostViewModel>());
}


<div class="profile-hero">
    <div class="profile-banner">
        @if (!string.IsNullOrEmpty(Model.BannerPicture))
        {
            <img src="@Model.BannerPicture" class="profile-banner-img" alt="Banner" />
        }
        else if (!string.IsNullOrEmpty(Model.BannerColor))
        {
            <div class="profile-banner-color" style="background-color: @Model.BannerColor;"></div>
        }
        else
        {
            <div class="profile-banner-color profile-banner-default"></div>
        }
        <div class="profile-banner-fade"></div>
    </div>

    <div class="profile-avatar-wrap">
        <img src="@(Model.ProfilePicture ?? "/defaults/default_icon.png")"
             alt="Profile picture of @Model.User?.UserName"
             class="profile-avatar-img" />
    </div>
</div>


<div class="profile-identity">
    <div class="profile-identity-names">
        <span class="profile-display-name">@Model.User?.DisplayName</span>
        <span class="profile-username">@@@Model.User?.UserName?.ToLower()
            @if (ViewBag.userIsPrivate == true)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" style="margin-left:5px">
                    <path stroke="var(--spark-text-muted)"
                          stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 14v2m-4-6V8a4 4 0 1 1 8 0v2m-9 9h10a1 1 0 0 0 1-1v-7a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1v7a1 1 0 0 0 1 1" />
                </svg>
            }
        </span>

    </div>
    <div class="profile-identity-actions">
        @if (isOwner)
        {
            <a href="@Url.Action("Edit", "Profile")" class="spark-edit-btn">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                </svg>
                Edit Profile
            </a>
            <a href="/Identity/Account/Manage" class="spark-edit-btn">Account Settings</a>
            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "", feed = "following" })"
                  class="spark-delete-form">
                <button type="submit" class="spark-delete-btn">Logout</button>
            </form>
        }
        else if (User.Identity.IsAuthenticated)
        {
            @if (!userFollowing.Contains(Model.UserId ?? string.Empty))
            {
                <form asp-action="SendFollowRequest" asp-controller="Connections"
                      class="follow-button" data-author-id="@Model.UserId">
                    <button type="submit" class="spark-follow-btn">Follow</button>
                </form>
            }
            else if (ViewBag.Pending)
            {
                <span class="profile-following-badge">Pending</span>
            }
            else
            {
                <form asp-action="SendFollowRequest" asp-controller="Connections"
                      class="follow-button" data-author-id="@Model.UserId">
                    <button type="submit" class="spark-follow-btn">Unfollow</button>
                </form>
            }
        }
    </div>
</div>

<!-- ── Posts feed ────────────────────────────────────────── -->
<div class="profile-section-rule" role="group">
    <!-- reloading page based on chosen feed -->
    <button type="button"
            class="spark-top-bar-btn @(currentFeed == "feed" ? "active" : "")"
            onclick="window.location.href='@Url.Action("Show", "Profile", new {id = Model.UserId, feed = "feed" })'">
        Feed
    </button>

    <button type="button"
            class="spark-top-bar-btn @(currentFeed == "highlighted" ? "active" : "")"
            onclick="window.location.href='@Url.Action("Show", "Profile", new { id = Model.UserId, feed = "highlighted" })'">
        Highlighted
    </button>
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="spark-post-feed">
            <div class="spark-posts-feed">
                @if (postsToDisplay.Any())
                {
                    @foreach (var post in postsToDisplay)
                    {
                        var previewModel = new
                        {
                            PostViewModel = post,
                            UserFollowing = userFollowing
                        };
                        <partial name="PostPreviewPartial" model="previewModel" />
                    }
                }
                else
                {
                    <div class="spark-end-feed">
                        <h5>No sparks yet.</h5>
                    </div>
                }
                <div class="spark-end-feed">
                    <h5>Oops... end of the road!</h5>
                </div>
            </div>
        </div>
    </div>
</div>

<style>


</style>

<script>
    document.querySelectorAll('.follow-button').forEach(form => {
        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            const button = this.querySelector('.spark-follow-btn');
            if (!button || button.disabled) return;
            button.disabled = true;
            const authorId = this.getAttribute('data-author-id');
            const endpoint = `/Connections/SendFollowRequest?followedId=${authorId}`;
            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    }
                });
                if (response.ok) this.style.display = 'none';
            } catch (error) {
                console.error('Follow error:', error);
            } finally {
                if (button) button.disabled = false;
            }
        });
    });
</script>
