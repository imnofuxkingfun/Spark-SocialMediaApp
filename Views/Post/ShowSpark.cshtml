@model Spark

@{
    ViewData["Title"] = "Spark";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Post Content -->
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">@Model.Author?.UserName</h5>
                            <small class="text-muted">@Model.CreatedAt.ToString("g")</small>
                        </div>
                        @if (User.Identity.IsAuthenticated && (Model.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                        {
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("EditSpark", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a href="@Url.Action("DeletePost", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">@Model.Text</p>
                    @if (Model.Media != null && Model.Media.Count > 0)
                    {
                        <div class="row g-2">
                            @foreach (var media in Model.Media.Take(4))
                            {
                                <div class="col-md-6">
                                    <img src="@media" alt="Post media" class="img-fluid" style="max-width: 100%; height: auto;">
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" action="@Url.Action("LikePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-heart"></i> Like
                                </button>
                            </form>
                            <form method="post" action="@Url.Action("SavePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-bookmark"></i> Save
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!--Comments Partial-->
            <partial name="CommentViewPartial" model="Model" />

            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Feed</a>
            </div>
        </div>
    </div>
</div>
