@model Spark

@{
    ViewData["Title"] = "Spark";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Post Content -->
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-1">@Model.Author?.UserName</h5>
                            <small class="text-muted">@Model.CreatedAt.ToString("g")</small>
                        </div>
                        @if (User.Identity.IsAuthenticated && (Model.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                        {
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("EditSpark", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a href="@Url.Action("DeletePost", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <p class="card-text">@Model.Text</p>
                    @if (Model.Media != null && Model.Media.Count > 0)
                    {
                        <div class="row g-2">
                            @foreach (var media in Model.Media.Take(4))
                            {
                                <div class="col-md-6">
                                    <img src="@media" alt="Post media" class="img-fluid" style="max-width: 100%; height: auto;">
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="card-footer bg-light">
                    <div class="d-flex gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" action="@Url.Action("LikePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-heart"></i> Like
                                </button>
                            </form>
                            <form method="post" action="@Url.Action("SavePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-bookmark"></i> Save
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Comments (@(Model.Comments?.Count ?? 0))</h5>
                </div>
                <div class="card-body">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form method="post" action="@Url.Action("AddComment", "Post")" class="mb-4">
                            <div class="mb-3">
                                <textarea class="form-control" name="text" maxlength="300" rows="3" placeholder="Add a comment..." required></textarea>
                                <small class="text-muted">Max 300 characters</small>
                            </div>
                            <input type="hidden" name="postId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary btn-sm">Post Comment</button>
                        </form>
                    }
                    else
                    {
                        <p class="text-muted"><a href="/Identity/Account/Login">Sign in</a> to comment on this post.</p>
                    }

                    <!-- Comments List -->
                    @if (Model.Comments != null && Model.Comments.Count > 0)
                    {
                        <div class="comments-list">
                            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                            {
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="card-subtitle mb-1">@comment.Author?.UserName</h6>
                                                <small class="text-muted">@comment.CreatedAt.ToString("g")</small>
                                            </div>
                                            @if (User.Identity.IsAuthenticated && (comment.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                                            {
                                                <div class="btn-group" role="group">
                                                    <a href="#editComment@(comment.Id)" class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse">Edit</a>
                                                    <form method="post" action="@Url.Action("DeleteComment", "Comment")" class="d-inline">
                                                        <input type="hidden" name="id" value="@comment.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this comment?')">Delete</button>
                                                    </form>
                                                </div>
                                            }
                                        </div>
                                        <p class="card-text mt-2">@comment.Text</p>
                                        @if (!string.IsNullOrEmpty(comment.Media))
                                        {
                                            <img src="@comment.Media" alt="Comment media" class="img-fluid" style="max-width: 100%; max-height: 200px;">
                                        }

                                        <!-- Edit Comment Form -->
                                        @if (User.Identity.IsAuthenticated && comment.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <div class="collapse mt-3" id="editComment@(comment.Id)">
                                                <form method="post" action="@Url.Action("EditComment", "Comment")" class="card card-body">
                                                    <input type="hidden" name="id" value="@comment.Id" />
                                                    <div class="mb-3">
                                                        <textarea class="form-control" name="text" maxlength="300" rows="2">@comment.Text</textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-primary btn-sm">Update Comment</button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">No comments yet. Be the first to comment!</p>
                    }
                </div>
            </div>

            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Back to Feed</a>
            </div>
        </div>
    </div>
</div>
