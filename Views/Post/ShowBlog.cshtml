@model Blog

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Blog Post Content -->
            <article class="card mb-4">
                <div class="card-header bg-light">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="h3 mb-2">@Model.Title</h1>
                            <div>
                                <small class="text-muted">by @Model.Author?.UserName</small><br />
                                <small class="text-muted">@Model.CreatedAt.ToString("f")</small>
                            </div>
                        </div>
                        @if (User.Identity.IsAuthenticated && (Model.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                        {
                            <div class="btn-group" role="group">
                                @if (User.Identity.IsAuthenticated && (Model.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value))
                                {
                                    <a href="@Url.Action("EditBlog", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-primary">Edit</a>
                                }
                                <form method="post" action="@Url.Action("DeletePost", "Post")" class="d-inline">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this blog?')">Delete</button>
                                </form>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-body">
                   

                    <hr />

                    <div class="blog-content">
                        @Html.Raw(System.Web.HttpUtility.HtmlEncode(Model.Text)?.Replace(Environment.NewLine, "<br>"))
                    </div>

                    @if (Model.Media != null && Model.Media.Count > 0)
                    {
                        <hr />
                        <div class="mt-4">
                            <h5>Gallery</h5>
                            <div class="row g-3">
                                @foreach (var media in Model.Media.Take(12))
                                {
                                    <div class="col-md-4">
                                        <figure class="figure w-100">
                                            <img src="@media" class="figure-img img-fluid" alt="Blog image" style="height: 250px; object-fit: cover;">
                                        </figure>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" action="@Url.Action("LikePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-heart"></i> Like
                                </button>
                            </form>
                            <form method="post" action="@Url.Action("SavePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-bookmark"></i> Save
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </article>

            <!-- Comments -->
            <partial name="CommentViewPartial" model="Model" />

            <!-- Navigation -->
            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">← Back to Feed</a>
            </div>
        </div>
    </div>
</div>
