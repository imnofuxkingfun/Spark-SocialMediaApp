@model Blog

@{
    ViewData["Title"] = Model.Title;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isOwnerOrAdmin = User.Identity.IsAuthenticated && (Model.AuthorId == currentUserId || User.IsInRole("Admin"));
    var isOwner = User.Identity.IsAuthenticated && Model.AuthorId == currentUserId;
    var interactionModel = ViewBag.InteractionModel;
    var UserFollowing = ViewBag.Following;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="show-spark-wrapper">

            <div class="spark-card-container">
                <div class="spark-card blog-show-card">

                    <!-- Avatar -->
                    <img class="spark-avatar"
                         src="@(Model.Author?.Profile?.ProfilePicture ?? "/defaults/default_icon.png")"
                         alt="Profile picture of @Model.Author?.UserName" style="cursor:pointer;"
                         onclick="window.location.href='@Url.Action("Show", "Profile", new { id = Model.AuthorId, feed = "feed" })'" />

                    <div class="spark-content">

                        <!-- Header: name + actions -->
                        <div class="spark-post-header">
                            <div class="spark-user-info">
                                <span class="spark-post-name">@Model.Author?.DisplayName</span>
                                <span class="spark-post-username">@@@Model.Author?.UserName?.ToLower()</span>
                                <span class="spark-post-timestamp">
                                    @Model.CreatedAt.ToString("g") | @Model.Privacy.ToString()
                                    @foreach (var warning in Model.ContentFilters)
                                    {
                                        @(warning.Value == true ? "| " + warning.Key + " " : "")
                                        ;
                                    }

                                </span>
                            </div>
                            <div class="spark-owner-actions">
                                @if (!UserFollowing.Contains(Model.AuthorId ?? string.Empty))
                                {
                                    <form asp-action="SendFollowRequest" asp-controller="Connections" class="follow-button" data-author-id="@Model.AuthorId">
                                        <button type="submit" class="spark-follow-btn">Follow</button>
                                    </form>
                                }
                                @if (isOwnerOrAdmin)
                                {
                                    var canEdit = (DateTime.UtcNow - Model.CreatedAt).TotalMinutes <= 15;

                               
                                    @if (isOwner)
                                    {
                                        <form method="post" action="@Url.Action("Highlight", "Post")" class="spark-delete-form">
                                            <input type="hidden" name="postId" value="@Model.Id" />
                                            <button type="submit" class="spark-edit-btn">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M6 3h11l3.902 5.573L11.5 22L2.098 8.573L6 3Zm4.162 1L8.464 8h6.072l-1.698-4h-2.676ZM8.327 9l3.173 9.764L14.672 9H8.328ZM3.72 8h3.658l1.698-4H6.52l-2.8 4Zm-.102 1l6.825 9.747L7.276 9H3.618ZM19.28 8l-2.8-4h-2.556l1.698 4h3.658Zm.102 1h-3.658l-3.167 9.747L19.382 9Z" />
                                                </svg>

                                                @(Model.IsHighlighted == true ? "Dull" : "Shine")
                                            </button>
                                        </form>

                                        @if (canEdit)
                                        {
                                            <a href="#editSpark@(Model.Id)"
                                               data-bs-toggle="collapse"
                                               class="spark-edit-btn">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                                Edit
                                            </a>
                                        }
                                    }
                                    <form method="post" action="@Url.Action("DeletePost", "Post")" class="spark-delete-form">
                                        <input type="hidden" name="id" value="@Model.Id" />
                                        <button type="submit" class="spark-delete-btn" onclick="return confirm('Delete this spark?')">
                                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6l-1 14H6L5 6" />
                                                <path d="M10 11v6" />
                                                <path d="M14 11v6" />
                                                <path d="M9 6V4h6v2" />
                                            </svg>
                                            Delete
                                        </button>
                                    </form>

                                }
                            </div>
                        </div>

                        <!-- Blog title -->
                        <div class="blog-show-title-wrap">
                            <h1 class="blog-show-title">@Model.Title</h1>
                            <div class="blog-show-title-rule"></div>
                        </div>


                        <!-- Blog body text -->
                        <div class="blog-show-body">
                            @Html.Raw(System.Web.HttpUtility.HtmlEncode(Model.Text)?.Replace(Environment.NewLine, "<br>"))
                        </div>

                        <!-- Gallery -->
                        @if (Model.Media != null && Model.Media.Count > 0)
                        {
                            var galleryImages = Model.Media.Take(12).ToList();
                            <div class="blog-show-gallery grid-@Math.Min(12, galleryImages.Count)">
                                @{
                                    var gIdx = 0;
                                }
                                @foreach (var media in galleryImages)
                                {
                                    gIdx++;
                                    <img src="@media"
                                         class="blog-gallery-img grid-image-@gIdx"
                                         alt="Blog image @gIdx"
                                         style="cursor:pointer;"
                                         onclick="openGalleryLightbox(@(gIdx - 1))" />
                                }
                            </div>

                            <!-- Lightbox -->
                            <div id="blogLightbox" class="spark-lightbox" onclick="closeLightbox(event)">
                                <button class="lightbox-arrow arrow-left" onclick="changeGalleryImage(-1, event)">
                                    @(galleryImages.Count > 1 ? Html.Raw("&#10094;") : "")
                                </button>
                                <img id="blogLightboxImg" class="lightbox-img" src="" alt="Full view" />
                                <button class="lightbox-arrow arrow-right" onclick="changeGalleryImage(1, event)">
                                    @(galleryImages.Count > 1 ? Html.Raw("&#10095;") : "")
                                </button>
                            </div>
                        }

                    </div>
                </div>

                <!-- Interaction bar -->
                @if (interactionModel != null)
                {
                    <partial name="PostInteractionSystemPartial" model="interactionModel" />
                }
            </div>

            <!-- Comments -->
            <partial name="CommentViewPartial" model="Model" />

            <!-- Back link -->
            <div class="spark-show-back">
                <a href="@Url.Action("Index", "Home", new { feed = "following" })" class="spark-back-link">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12" />
                        <polyline points="12 19 5 12 12 5" />
                    </svg>
                    Back to Feed
                </a>
            </div>

        </div>
    </div>
</div>


<script>
    // Gallery lightbox
    const galleryImages = Array.from(document.querySelectorAll('.blog-gallery-img')).map(img => img.src);
    let galleryIndex = 0;
    const blogLightbox = document.getElementById('blogLightbox');
    const blogLightboxImg = document.getElementById('blogLightboxImg');

    function openGalleryLightbox(index) {
        galleryIndex = index;
        blogLightboxImg.src = galleryImages[galleryIndex];
        blogLightbox.classList.add('active');
        document.addEventListener('keydown', handleGalleryKey);
    }

    function closeLightbox(e) {
        if (e.target === blogLightbox || e.target.classList.contains('spark-lightbox')) {
            blogLightbox.classList.remove('active');
            document.removeEventListener('keydown', handleGalleryKey);
        }
    }

    function changeGalleryImage(dir, e) {
        if (e) e.stopPropagation();
        galleryIndex = (galleryIndex + dir + galleryImages.length) % galleryImages.length;
        blogLightboxImg.src = galleryImages[galleryIndex];
    }

    function handleGalleryKey(e) {
        if (e.key === 'ArrowRight') changeGalleryImage(1);
        if (e.key === 'ArrowLeft') changeGalleryImage(-1);
        if (e.key === 'Escape') {
            blogLightbox.classList.remove('active');
            document.removeEventListener('keydown', handleGalleryKey);
        }
    }
</script>
