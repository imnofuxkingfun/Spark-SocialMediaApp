@model Blog

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Blog Post Content -->
            <article class="card mb-4">
                <div class="card-header bg-light">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="h3 mb-2">@Model.Title</h1>
                            <div>
                                <small class="text-muted">by @Model.Author?.UserName</small><br />
                                <small class="text-muted">@Model.CreatedAt.ToString("f")</small>
                            </div>
                        </div>
                        @if (User.Identity.IsAuthenticated && (Model.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                        {
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("EditBlog", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a href="@Url.Action("DeletePost", "Post", new { id = Model.Id })" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                            </div>
                        }
                    </div>
                </div>

                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <p class="lead text-muted">@Model.Description</p>
                    }

                    <hr />

                    <div class="blog-content">
                        @Html.Raw(System.Web.HttpUtility.HtmlEncode(Model.Text)?.Replace(Environment.NewLine, "<br>"))
                    </div>

                    @* @if (Model.Description != null && Model.Description.Count > 0)
                    {
                        <hr />
                        <div class="mt-4">
                            <h5>Gallery</h5>
                            <div class="row g-3">
                                @foreach (var media in Model.Description.Take(12))
                                {
                                    <div class="col-md-4">
                                        <figure class="figure w-100">
                                            <img src="@media" class="figure-img img-fluid" alt="Blog image" style="height: 250px; object-fit: cover;">
                                        </figure>
                                    </div>
                                }
                            </div>
                        </div>
                    } *@
                </div>

                <div class="card-footer bg-light">
                    <div class="d-flex gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <form method="post" action="@Url.Action("LikePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-heart"></i> Like
                                </button>
                            </form>
                            <form method="post" action="@Url.Action("SavePost", "Post")" class="d-inline">
                                <input type="hidden" name="postId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-bookmark"></i> Save
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </article>

            <!-- Comments Section -->
            <section class="card">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Comments (@(Model.Comments?.Count ?? 0))</h4>
                </div>

                <div class="card-body">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form method="post" action="@Url.Action("AddComment", "Post")" class="mb-5 p-3 bg-light rounded">
                            <div class="mb-3">
                                <label for="commentText" class="form-label">Add Your Comment</label>
                                <textarea class="form-control" id="commentText" name="text" maxlength="300" rows="3" placeholder="Share your thoughts..." required></textarea>
                                <small class="text-muted">Max 300 characters</small>
                            </div>
                            <input type="hidden" name="postId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary">Post Comment</button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info" role="alert">
                            <a href="/Identity/Account/Login">Sign in</a> to comment on this blog post.
                        </div>
                    }

                    <!-- Comments List -->
                    @if (Model.Comments != null && Model.Comments.Count > 0)
                    {
                        <div class="comments-section">
                            @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                            {
                                <div class="card mb-3 border-0 border-bottom">
                                    <div class="card-body pb-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="card-subtitle fw-bold mb-1">@comment.Author?.UserName</h6>
                                                <small class="text-muted">@comment.CreatedAt.ToString("g")</small>
                                            </div>
                                            @if (User.Identity.IsAuthenticated && (comment.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value || User.IsInRole("Admin")))
                                            {
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#editForm@(comment.Id)">Edit</button>
                                                    <form method="post" action="@Url.Action("DeleteComment", "Comment")" class="d-inline">
                                                        <input type="hidden" name="id" value="@comment.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this comment?')">Delete</button>
                                                    </form>
                                                </div>
                                            }
                                        </div>

                                        <p class="card-text">@comment.Text</p>

                                        @if (!string.IsNullOrEmpty(comment.Media))
                                        {
                                            <div class="mt-2">
                                                <img src="@comment.Media" alt="Comment media" class="img-fluid rounded" style="max-width: 300px; max-height: 300px;">
                                            </div>
                                        }

                                        <!-- Edit Comment Form -->
                                        @if (User.Identity.IsAuthenticated && comment.AuthorId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <div class="collapse mt-3" id="editForm@(comment.Id)">
                                                <form method="post" action="@Url.Action("EditComment", "Comment")" class="card card-body bg-light">
                                                    <input type="hidden" name="id" value="@comment.Id" />
                                                    <div class="mb-2">
                                                        <textarea class="form-control form-control-sm" name="text" maxlength="300" rows="2">@comment.Text</textarea>
                                                    </div>
                                                    <button type="submit" class="btn btn-primary btn-sm">Update</button>
                                                </form>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No comments yet. Be the first to share your thoughts!</p>
                    }
                </div>
            </section>

            <!-- Navigation -->
            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">← Back to Feed</a>
            </div>
        </div>
    </div>
</div>
