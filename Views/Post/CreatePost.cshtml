@{
    ViewData["Title"] = "Create Post";
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <h4 class="alert-heading">Validation Errors</h4>
        @Html.ValidationSummary(false)
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1>Create a New Post</h1>

            <div class="btn-group mb-4" role="group">
                <button type="button" class="btn btn-outline-primary" onclick="showSparkForm()">Create Spark</button>
                <button type="button" class="btn btn-outline-primary" onclick="showBlogForm()">Create Blog</button>
            </div>

            <!-- Spark Form -->
            <div id="sparkForm" style="display: none;">
                <h3>Create a Spark</h3>
                <form method="post" action="@Url.Action("CreateSpark", "Post")" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="sparkText" class="form-label">What's on your mind?</label>
                        <textarea class="form-control" id="sparkText" name="text" maxlength="500" rows="4" placeholder="Share your thoughts (max 500 characters)"></textarea>
                        <small class="text-muted">Max 500 characters</small>
                    </div>

                    <div class="mb-3">
                        <label for="sparkMedia" class="form-label">Add Media (up to 4 images)</label>
                        <input type="file" class="form-control" id="sparkMedia" name="media" multiple accept="image/*">
                        <small class="text-muted">You can upload up to 4 images</small>
                    </div>
                    <div class="mb-3">
                        <label for="sparkPrivacy" class="form-label">Privacy</label>
                        <select class="form-select" id="sparkPrivacy" name="privacy">
                            <!option value="public" @(ViewBag.PrivacyPublic ? "selected" : "") >Public</!option>
                            <!option value="private" @(ViewBag.PrivacyPublic ? "" : "selected")>Private</!option>
                            <option value="close friends">Close Friends</option>
                        </select>
                    </div>

                    <h5>Content Warnings</h5>
                    @if (ViewBag.ContentFilters != null)
                    {
                        @foreach (var filter in ViewBag.ContentFilters)
                        {
                            <div class="mb-3">
                                <div class="form-check">
                                    <input type="hidden" name="ContentWarnings[@filter.Key]" value="false">
                                    <input type="checkbox" class="form-check-input" id="ContentWarnings_@filter.Key" name="ContentWarnings[@filter.Key]" value="true" @(filter.Value ? "checked" : "")>
                                    <label class="form-check-label" for="ContentWarnings_@filter.Key">@filter.Key</label>
                                </div>
                            </div>
                        }
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Post Spark</button>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>

            <!-- Blog Form -->
            <div id="blogForm" style="display: none;">
                <h3>Create a Blog</h3>
                <form method="post" action="@Url.Action("CreateBlog", "Post")" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="blogTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="blogTitle" name="title" required placeholder="Enter blog title">
                    </div>

                    <div class="mb-3">
                        <label for="blogText" class="form-label">Content</label>
                        <textarea class="form-control" id="blogText" name="text" maxlength="5000" rows="8" placeholder="Write your blog content (max 5000 characters)"></textarea>
                        <small class="text-muted">Max 5000 characters</small>
                    </div>

                    <div class="mb-3">
                        <label for="blogImages" class="form-label">Add Images (up to 12 images)</label>
                        <input type="file" class="form-control" id="blogImages" name="images" multiple accept="image/*">
                        <small class="text-muted">You can upload up to 12 images</small>
                    </div>

                    <div class="mb-3">
                        <label for="blogPrivacy" class="form-label">Privacy</label>
                        <select class="form-select" id="blogPrivacy" name="privacy">
                            <option value="">Default (based on your settings)</option>
                            <option value="public">Public</option>
                            <option value="private">Private</option>
                            <option value="close friends">Close Friends</option>
                        </select>
                    </div>

                    <h5>Content Warnings</h5>
                    @if (ViewBag.ContentFilters != null)
                    {
                        @foreach (var filter in ViewBag.ContentFilters)
                        {
                            <div class="mb-3">
                                <div class="form-check">
                                    <input type="hidden" name="ContentWarnings[@filter.Key]" value="false">
                                    <input type="checkbox" class="form-check-input" id="ContentWarnings_blog_@filter.Key" name="ContentWarnings[@filter.Key]" value="true" @(filter.Value ? "checked" : "")>
                                    <label class="form-check-label" for="ContentWarnings_blog_@filter.Key">@filter.Key</label>
                                </div>
                            </div>
                        }
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Post Blog</button>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function showSparkForm() {
    document.getElementById('sparkForm').style.display = 'block';
    document.getElementById('blogForm').style.display = 'none';
    document.querySelectorAll('.btn-group button')[0].classList.add('active');
    document.querySelectorAll('.btn-group button')[1].classList.remove('active');
}

function showBlogForm() {
    document.getElementById('sparkForm').style.display = 'none';
    document.getElementById('blogForm').style.display = 'block';
    document.querySelectorAll('.btn-group button')[1].classList.add('active');
    document.querySelectorAll('.btn-group button')[0].classList.remove('active');
}

// Show Spark form by default
document.addEventListener('DOMContentLoaded', function() {
    showSparkForm();
});
</script>
