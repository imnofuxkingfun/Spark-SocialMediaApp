@{
    ViewData["Title"] = "Create Post";
}



<div class="container">
    <div class="row justify-content-center">
<div class="spark-post-feed mx-auto mt-5">
    <div class="spark-card-container">
        <div class="spark-card d-flex flex-column">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show border-0 mx-auto mt-4" role="alert" style="max-width: 1400px; width: 80%; background: rgba(220, 53, 69, 0.1); color: #ff6b6b; font-family: 'Trocchi', Georgia, serif;">
                            <h4 class="alert-heading" style="font-size: 24px;">Validation Errors</h4>
                            @Html.ValidationSummary(false)
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

            <div class="spark-post-header d-flex justify-content-between align-items-center w-100 mb-4">
                <div class="spark-user-info">
                    <h1 class="spark-post-name m-0" style="font-size: 36px;">Create a New Post</h1>
                </div>

                <!-- Custom Form Switcher Buttons aligned to styling -->
                <div class="btn-group" role="group">
                    <button type="button" class="spark-follow-btn me-2 active" onclick="showSparkForm(this)">Spark</button>
                    <button type="button" class="spark-follow-btn" onclick="showBlogForm(this)">Blog</button>
                </div>
            </div>

            <!-- Spark Form -->
            <div id="sparkForm" class="spark-content" style="display: none;">
                <div class="spark-blog-gradient">
                    <h3 class="spark-blog-title mb-4">Create a Spark</h3>
                    <form method="post" action="@Url.Action("CreateSpark", "Post")" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label for="sparkText" class="spark-text d-block mb-2">What's on your mind?</label>
                            <textarea class="form-control spark-input" id="sparkText" name="text" maxlength="500" rows="4"></textarea>
                            <small class="spark-post-timestamp d-block mt-1">Max 500 characters</small>
                        </div>

                                <div class="mb-4">
                                    <label for="tagsInput" class="spark-text d-block mb-2">Tags</label>
                                    <input type="text" class="form-control spark-input" id="tagsInput" name="tags" maxlength="100" placeholder="#fun #coding #life">
                                    <small class="spark-post-timestamp d-block mt-1">Max 100 characters. Separate tags with #</small>
                                </div>


                        <div class="mb-4">
                            <label for="sparkMedia" class="spark-text d-block mb-2">Add Media (up to 4 images)</label>
                            <input type="file" class="form-control spark-input" id="sparkMedia" name="media" multiple accept="image/*">
                                    <small class="spark-post-timestamp d-block mt-1">Max 5MB per image</small>
                        </div>

                        <div class="mb-4">
                            <label for="sparkPrivacy" class="spark-text d-block mb-2">Privacy</label>
                            <select class="form-select spark-input" id="sparkPrivacy" name="privacy">
                                <!option value="public" @(ViewBag.PrivacyPublic ? "selected" : "")>Public</!option>
                                <!option value="private" @(ViewBag.PrivacyPublic ? "" : "selected")>Private</!option>
                                @* <option value="close friends">Close Friends</option> *@
                            </select>
                        </div>

                        <h5 class="spark-text mb-3" style="color: rgba(121,121,121,0.8);">Content Warnings</h5>
                        @if (ViewBag.ContentFilters != null)
                        {
                            <div class="row mb-4">
                                @foreach (var filter in ViewBag.ContentFilters)
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input spark-checkbox" id="ContentWarnings_@filter.Key" name="ContentWarnings[@filter.Key]" value="true" @(filter.Value ? "checked" : "")>
                                                    <input type="hidden" name="ContentWarnings[@filter.Key]" value="false">

                                                    <label class="form-check-label spark-hashtags" style="font-size: 18px;" for="ContentWarnings_@filter.Key">@filter.Key</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="spark-follow-btn text-white" style="background: rgba(165,90,252,0.34);">Post Spark</button>
                            <a href="@Url.Action("Index", "Home")" class="spark-action-btn spark-action-count text-decoration-none">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Blog Form -->
            <div id="blogForm" class="spark-content" style="display: none;">
                <div class="spark-blog-gradient">
                    <h3 class="spark-blog-title mb-4">Create a Blog</h3>
                    <form method="post" action="@Url.Action("CreateBlog", "Post")" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label for="blogTitle" class="spark-text d-block mb-2">Title</label>
                                    <input type="text" class="form-control spark-input" style="font-size: 24px; color: white;" id="blogTitle" name="title" maxlength="100" required>
                        </div>

                        <div class="mb-4">
                            <label for="blogText" class="spark-text d-block mb-2">Content</label>
                            <textarea class="form-control spark-input" id="blogText" name="text" maxlength="5000" rows="8"></textarea>
                            <small class="spark-post-timestamp d-block mt-1">Max 5000 characters</small>
                        </div>

                                <div class="mb-4">
                                    <label for="tagsInput" class="spark-text d-block mb-2">Tags</label>
                                    <input type="text" class="form-control spark-input" id="tagsInput" name="tags" maxlength="100">
                                    <small class="spark-post-timestamp d-block mt-1">Max 100 characters. Separate tags with #</small>
                                </div>

                        <div class="mb-4">
                            <label for="blogImages" class="form-label spark-text d-block mb-2">Add Images (up to 12 images)</label>
                            <input type="file" class="form-control spark-input" id="blogImages" name="images" multiple accept="image/*">
                            <small class="spark-post-timestamp d-block mt-1">Max 5MB per image</small>
                        </div>

                                <div class="mb-4">
                                    <label for="sparkPrivacy" class="spark-text d-block mb-2">Privacy</label>
                                    <select class="form-select spark-input" id="sparkPrivacy" name="privacy">
                                        <!option value="public" @(ViewBag.PrivacyPublic ? "selected" : "")>Public</!option>
                                        <!option value="private" @(ViewBag.PrivacyPublic ? "" : "selected")>Private</!option>
                                        @* <option value="close friends">Close Friends</option> *@
                                    </select>
                                </div>

                        <h5 class="spark-text mb-3" style="color: rgba(121,121,121,0.8);">Content Warnings</h5>
                        @if (ViewBag.ContentFilters != null)
                        {
                            <div class="row mb-4">
                                @foreach (var filter in ViewBag.ContentFilters)
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input spark-checkbox" id="ContentWarnings_blog_@filter.Key" name="ContentWarnings[@filter.Key]" value="true" @(filter.Value ? "checked" : "")>
                                                    <input type="hidden" name="ContentWarnings[@filter.Key]" value="false">

                                            <label class="form-check-label spark-hashtags" style="font-size: 18px;" for="ContentWarnings_blog_@filter.Key">@filter.Key</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="spark-follow-btn text-white" style="background: rgba(165,90,252,0.34);">Post Blog</button>
                            <a href="@Url.Action("Index", "Home")" class="spark-action-btn spark-action-count text-decoration-none">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>


                    <!--parent post if it exists-->
                    @* <partial name="PostPreviewPartial" model="@ViewBag.ParentPost" /> *@

        </div>
    </div>
</div>
</div>
</div>
<style>
    .spark-input {
    background: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid rgba(165, 90, 252, 0.3) !important;
    color: rgba(255, 255, 255, 0.9) !important;
    font-family: 'Trocchi', Georgia, serif !important;
    font-size: 20px !important;
    border-radius: 4px !important;
    }

    .spark-input:focus {
    background: rgba(var(--spark-accent-rgb), 0.05) !important;
    border-color: #A55AFC !important;
    box-shadow: 0 0 8px rgba(165, 90, 252, 0.4) !important;
    outline: none;
    }

    .spark-input option {
    background: #1a1a1a !important;
    color: white !important;
    }

    .spark-checkbox {
    background-color: rgba(255, 255, 255, 0.03) !important;
    border: 1px solid #A55AFC !important;
    }

    .spark-checkbox:checked {
    background-color: #A55AFC !important;
    border-color: #A55AFC !important;
    }

    .spark-follow-btn.active {
    color: white !important;
    background: rgba(165, 90, 252, 0.4) !important;
    box-shadow: 0 0 10px rgba(165, 90, 252, 0.2);
    }
</style>

<script>
    function showSparkForm() {
        document.getElementById('sparkForm').style.display = 'block';
        document.getElementById('blogForm').style.display = 'none';
        document.querySelectorAll('.btn-group button')[0].classList.add('active');
        document.querySelectorAll('.btn-group button')[1].classList.remove('active');
    }

    function showBlogForm() {
        document.getElementById('sparkForm').style.display = 'none';
        document.getElementById('blogForm').style.display = 'block';
        document.querySelectorAll('.btn-group button')[1].classList.add('active');
        document.querySelectorAll('.btn-group button')[0].classList.remove('active');
    }

    // Show Spark form by default
    document.addEventListener('DOMContentLoaded', function() {
        showSparkForm();
    });

    //spark check max 4 files + size
    const sparkMediaInput = document.getElementById('sparkMedia');
    const maxSparkImages = 4;
    const maxSize = 5 * 1024 * 1024; // 5MB in bytes

    sparkMediaInput.addEventListener('change', (e) => {
        let files = Array.from(e.target.files);
        let validFiles = [];

        for (let file of files) {
            if (file.size > maxSize) {
                alert(`"${file.name}" exceeds file size limit. Maximum file size is 5MB.`);
            } else {
                validFiles.push(file);
            }
        }

        if (validFiles.length > maxSparkImages) {
            alert(`You can only upload a maximum of ${maxSparkImages} images!`);
            validFiles = validFiles.slice(0, maxSparkImages); //keep first 4 valid files
        }

        const dataTransfer = new DataTransfer();
        validFiles.forEach(file => dataTransfer.items.add(file));
        sparkMediaInput.files = dataTransfer.files;
    });

    //blog check max 12 files + size
    const blogMediaInput = document.getElementById('blogImages');
    const maxBlogImages = 12;

    blogMediaInput.addEventListener('change', (e) => {
        let files = Array.from(e.target.files);
        let validFiles = [];

        for (let file of files) {
            if (file.size > maxSize) {
                alert(`"${file.name}" exceeds file size limit. Maximum file size is 5MB.`);
            } else {
                validFiles.push(file);
            }
        }

        if (validFiles.length > maxBlogImages) {
            alert(`You can only upload a maximum of ${maxBlogImages} images!`);
            validFiles = validFiles.slice(0, maxBlogImages); //keep first 4 valid files
        }

        const dataTransfer = new DataTransfer();
        validFiles.forEach(file => dataTransfer.items.add(file));
        blogMediaInput.files = dataTransfer.files;
    });


</script>
