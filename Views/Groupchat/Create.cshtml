@{
    ViewData["Title"] = "Create Group Chat";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create New Group Chat</h4>
                </div>
                <div class="card-body">
                    <form method="post" action="@Url.Action("Create", "Groupchat")">
                        <div class="mb-3">
                            <label for="groupchatName" class="form-label">Group Name</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="groupchatName" 
                                   name="name" 
                                   required 
                                   placeholder="Enter group chat name">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Add Members</label>
                            <div id="membersList" class="border rounded p-3" style="max-height: 300px; overflow-y: auto;">
                                <p class="text-muted">Loading users...</p>
                            </div>
                            <small class="text-muted">Select members to add to the group chat</small>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create Group Chat</button>
                            <a href="@Url.Action("Index", "Groupchat")" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Placeholder for loading users
document.addEventListener('DOMContentLoaded', function() {
    // This would typically load from an API endpoint
    // For now, the form will accept manual member addition through controller
    const membersList = document.getElementById('membersList');
    membersList.innerHTML = '<p class="text-muted">Add members after creating the group chat</p>';
});
</script>
