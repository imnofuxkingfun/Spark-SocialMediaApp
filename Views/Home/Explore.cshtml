@{
    ViewData["Title"] = "Explore";
    var posts = ViewBag.Posts as List<Post> ?? new List<Post>();
    var userFollowing = ViewBag.Following as List<string> ?? new List<string>();
}
<!--top bar-->
<div class="spark-top-bar glass-effect" role="group">
    <button type="button" class="spark-top-bar-btn" onClick="showForYou(event)">For You</button>
    <button type="button" class="spark-top-bar-btn" onClick="showTrending(event)">Trending </button>
    <button type="button" class="spark-top-bar-btn-svg" onclick="settingsPopUp()">
        <svg width=" 48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
