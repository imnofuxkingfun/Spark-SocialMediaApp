@{
    ViewData["Title"] = "Home";
    var posts = ViewBag.Posts as List<Post> ?? new List<Post>();
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Create Post Button -->
            <div class="mb-4">
                <a href="@Url.Action("CreatePost", "Post")" class="btn btn-primary btn-lg w-100">
                    <i class="bi bi-pencil"></i> Create New Post
                </a>
            </div>

            <!-- Posts Feed -->
            @if (posts.Count > 0)
            {
                <div class="posts-feed">
                    @foreach (var post in posts.OrderByDescending(p => p.CreatedAt))
                    {
                        <div class="card mb-4">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-1">@post.Author?.UserName</h6>
                                        <small class="text-muted">@post.CreatedAt.ToString("g")</small>
                                    </div>
                                    <span class="badge bg-secondary">
                                        @(post.GetType().Name)
                                    </span>
                                </div>
                            </div>
                            <div class="card-body">
                                @if (post is Spark spark)
                                {
                                    <p class="card-text">@spark.Text</p>
                                    @if (spark.Media != null && spark.Media.Count > 0)
                                    {
                                        <div class="row g-2 mt-3">
                                            @foreach (var media in spark.Media.Take(4))
                                            {
                                                <div class="col-md-6">
                                                    <img src="@media" alt="Post media" class="img-fluid rounded" style="max-height: 300px; object-fit: cover;">
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else if (post is Blog blog)
                                {
                                    <h5>@blog.Title</h5>
                                    <p class="card-text">@blog.Text.Substring(0, Math.Min(200, blog.Text?.Length ?? 0))...</p>
                                    @if (blog.Media != null && blog.Media.Count > 0)
                                    {
                                        <div class="row g-2 mt-3">
                                            @foreach (var media in blog.Media.Take(4))
                                            {
                                                <div class="col-md-6">
                                                    <img src="@media" alt="Post media" class="img-fluid rounded" style="max-height: 300px; object-fit: cover;">
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                            <div class="card-footer bg-light">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex gap-2">
                                        <small class="text-muted">
                                            <i class="bi bi-chat"></i> @(post.Comments?.Count ?? 0) Comments
                                        </small>
                                        <small class="text-muted">
                                            <i class="bi bi-heart"></i> @(post.LikedByUsers?.Count ?? 0) Likes
                                        </small>
                                    </div>
                                    <a href="@Url.Action("Show", "Post", new { id = post.Id })" class="btn btn-sm btn-outline-primary">
                                        View Post
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info text-center" role="alert">
                    <h5>No posts yet</h5>
                    <p class="mb-0"><a href="@Url.Action("CreatePost", "Post")">Create the first post</a> and start engaging with the community!</p>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Links</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Index", "Profile")" class="list-group-item list-group-item-action">
                        <i class="bi bi-person-circle"></i> My Profile
                    </a>
                    <a href="@Url.Action("ShowFollowRequests", "Connections")" class="list-group-item list-group-item-action">
                        <i class="bi bi-person-plus"></i> Follow Requests
                    </a>
                    <a href="@Url.Action("Index", "Groupchat")" class="list-group-item list-group-item-action">
                        <i class="bi bi-chat-dots"></i> Group Chats
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
