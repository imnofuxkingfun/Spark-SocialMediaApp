@page
@model ResetPasswordConfirmationModel
@{
    ViewData["Title"] = "Reset password confirmation";
}

<h1>@ViewData["Title"]</h1>
<div class="container">
    <div class="row justify-content-center">
        <div class="spark-post-feed">
            <div class=" spark-posts-feed">
                <div style="height:12vh"></div>
                <div class=" muted-text" style="font-size:2rem; display:flex; justify-content: center;">
<p>
    Your password has been reset. Please <a asp-page="./Login">click here to log in</a>.
</p>
                </div>
            </div>
        </div>
    </div>
</div>

