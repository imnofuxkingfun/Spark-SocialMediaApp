@page
@using Spark_SocialMediaApp.Models
@model SettingsModel
@{
    ViewData["Title"] = "Settings";
    ViewData["ActivePage"] = ManageNavPages.Settings;
}

<form id="update-settings-form" method="post">
    <div class="mb-3">
        <div class="form-check">
            <input asp-for="Settings.PrivacyPublic" class="form-check-input" id="PrivacyPublic" />
            <input type="hidden" asp-for="Settings.UserId" />
            <label class="form-check-label" for="PrivacyPublic">Public Profile</label>
        </div>
    </div>

    <h3>Content Filters</h3>

    @{
        var filterKeys = Model.Settings.ContentFilters.Keys.ToList();
    }

    @for (int i = 0; i < filterKeys.Count; i++)
{
    var key = filterKeys[i];
    <div class="mb-3">
        <div class="form-check">
            <input type="hidden" name="FormFilters[@i].Key" value="@key" />
            
            <input type="checkbox" 
                   class="form-check-input" 
                   id="ContentFilters_@key" 
                   name="FormFilters[@i].Value" 
                   value="true" 
                   @(Model.Settings.ContentFilters[key] ? "checked" : "") />
                   
            <input type="hidden" name="FormFilters[@i].Value" value="false" />

            <label class="form-check-label" for="ContentFilters_@key">@key</label>
        </div>
    </div>
}


    <button type="submit" class="btn btn-primary">Apply</button>
</form>
